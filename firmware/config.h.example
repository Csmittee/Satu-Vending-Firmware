// config.h — machine-specific build configuration
// Copy to config.h before flashing. config.h is gitignored — never commit it.
//
// WiFi credentials: leave empty strings. Credentials are entered via the
// touchscreen WiFi setup screen on first boot and stored in NVS (R-85).
// DO NOT fill in WIFI_SSID or WIFI_PASSWORD here.

// ── WiFi (intentionally empty — R-85) ───────────────────────────────
#define WIFI_SSID     ""
#define WIFI_PASSWORD ""

// ── Slot count ───────────────────────────────────────────────────────
// Maximum supported by hardware: 21 (7 cols × 3 rows, R-67)
#define NUM_SLOTS 21

// ── Vend timing ──────────────────────────────────────────────────────
// IR sensor poll cadence inside vendProduct() spin loop
#define SENSOR_POLL_MS 10

// Motor safety cutoff — stops relay if IR sensor never fires
#define VEND_MAX_SPIN_MS 30000

// ── Payment ──────────────────────────────────────────────────────────
// Time to wait for Omise webhook before returning to idle (ms)
#define PAYMENT_TIMEOUT 30000

// ── Product selection timeout (R-152) ────────────────────────────────
// Seconds before product selection screen returns to idle if no confirm tap.
// Overridden at runtime by NVS key cfg_sel if set by operator.
#define PRODUCT_SELECTION_TIMEOUT 15
